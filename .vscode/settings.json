{
  "eslint.enable": true,
  "prettier.enable": true,
  "editor.codeActionsOnSave": {
    "source.eslint.fixAll": "always"
  },
  "eslint.validate": [
    "vue",
    "yaml",
    "html",
    "json",
    "jsonc",
    "json5",
    "markdown",
    "javascript",
    "typescript",
    "javascriptreact",
    "typescriptreact"
  ],
  "cSpell.allowCompoundWords": true,
  "cSpell.words": ["bumpp", "changelogithub", "iconify", "Nuxt", "nuxtjs", "pinia", "vueuse"]
}
